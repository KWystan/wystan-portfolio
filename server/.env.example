# NVIDIA NIM key for the portfolio chat widget (/api/chat, uses Llama 4 Maverick)
NVIDIA_API_KEY=nvapi-YOUR_API_KEY_HERE

# OpenCode Zen key for the full chat page (/api/chat-full, streaming, uses MiMo-V2.5)
OPENCODE_API_KEY=oc_YOUR_API_KEY_HERE

# Optional: override the OpenCode base URL (defaults to https://opencode.ai/zen/v1)
# OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Optional: server port (defaults to 5000)
# PORT=5000
